    "preview": "deno run -A npm:vite preview"
  },
  "imports": {
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.0",
    "hls.js": "npm:hls.js@^1.6.16",
    "vite": "npm:vite@^6.3.0"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "deno.ns"],
    "strict": true
  }
}
